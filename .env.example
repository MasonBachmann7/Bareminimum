# ─── Neon (Postgres) ────────────────────────────────────────────────────────────
# Pooled connection string from Neon console. Server-only.
# https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL=postgres://<user>:<password>@<host>-pooler.<region>.neon.tech/<db>?sslmode=require
# Optional unpooled (for migrations / long-lived connections).
DATABASE_URL_UNPOOLED=postgres://<user>:<password>@<host>.<region>.neon.tech/<db>?sslmode=require

# ─── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Auth.js v5 + Resend ────────────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=
# Where the app is served from (used for magic-link callbacks).
AUTH_URL=http://localhost:3000
# Resend API key for magic-link email delivery.
RESEND_API_KEY=re_...
# "from" address — must be a verified sender on Resend.
AUTH_EMAIL_FROM=bareminimum <noreply@yourdomain.tld>

# ─── Crypto ─────────────────────────────────────────────────────────────────────
# Symmetric key passed to pgcrypto. Long, random, and irreplaceable — rotating it
# invalidates every stored PAT. Generate with: `openssl rand -base64 48`
PAT_ENCRYPTION_KEY=

# ─── Cron ───────────────────────────────────────────────────────────────────────
# Bearer secret required to call POST /api/cron/tick.
CRON_SECRET=
